{
  "name": "contest-widget",
  "version": "1.0.0",
  "description": "Smart Coding Contest Desktop Widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "widget",
    "competitive-programming"
  ],
  "author": "ContestPulse Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "electron-reloader": "^1.2.3"
  },
  "build": {
    "appId": "com.contestpulse.widget",
    "productName": "ContestPulse",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "zip",
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ContestPulse"
    },
    "files": [
      "**/*",
      "!dist",
      "!*.md",
      "!*.ps1",
      "!create_installer.js",
      "!.gitignore",
      "!.git"
    ]
  }
}
